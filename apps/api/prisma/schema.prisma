generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Wine {
  id               String   @id
  name             String
  producer         String
  vintage          Int
  region           String
  country          String
  type             String
  grape            String
  quantity         Int      @default(0)
  purchasePrice    Float    @default(0)
  purchaseDate     String   @default("")
  purchaseLocation String   @default("")
  storageLocation  String?
  drinkFrom        Int      @default(0)
  drinkUntil       Int      @default(0)
  rating           Float?
  ratingSource     String?
  personalRating   Float?
  notes            String?
  imageUri         String?
  imageUrl         String?
  imageData        String?
  /// JSON array of up to 3 images; SQL migrations enforce count and payload-size checks.
  images           Json?
  purchaseLink     String?
  isGift           Boolean  @default(false)
  giftFrom         String?
  isRarity         Boolean  @default(false)
  bottleSize       String?
  updatedAt        DateTime @updatedAt
  wineImages       WineImage[]

  @@map("wines")
}

model WishlistItem {
  id             String   @id
  name           String
  producer       String?
  vintage        Int?
  type           String?
  region         String?
  country        String?
  grape          String?
  rating         Float?
  tastedDate     String?
  tastedLocation String?
  price          Float?
  imageUri       String?
  imageData      String?
  /// JSON array of up to 3 images; SQL migrations enforce count and payload-size checks.
  images         Json?
  tastingEvent   String?
  tastingSupplier String?
  tastingStand   String?
  location       String   @default("")
  occasion       String   @default("")
  companions     String   @default("")
  notes          String?
  createdAt      String
  source         String?
  sourceUrl      String?
  updatedAt      DateTime @updatedAt

  @@map("wishlist_items")
}

model ShoppingItem {
  id             String   @id
  name           String
  producer       String   @default("")
  quantity       Int      @default(1)
  estimatedPrice Float    @default(0)
  reason         String   @default("")
  checked        Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  @@map("shopping_items")
}

model ConsumedWine {
  id           String   @id
  wineId       String
  name         String
  producer     String
  vintage      Int
  type         String
  quantity     Int      @default(1)
  consumedDate String
  updatedAt    DateTime @updatedAt

  @@map("consumed_wines")
}

model CellarMovement {
  id           String   @id
  type         String
  wineId       String
  wineName     String
  wineProducer String
  wineVintage  Int
  wineType     String
  quantity     Int      @default(1)
  date         String
  occasion     String?
  updatedAt    DateTime @updatedAt

  @@map("cellar_movements")
}

model FeatureFlag {
  key       String   @id
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("feature_flags")
}

model WineImage {
  id         String   @id @default(cuid())
  wineId     String
  wine       Wine     @relation(fields: [wineId], references: [id], onDelete: Cascade)
  storageKey String   @unique
  url        String
  label      String?
  isPrimary  Boolean  @default(false)
  bytes      Int?
  createdAt  DateTime @default(now())

  @@index([wineId])
  @@map("wine_images")
}

model CaptureSession {
  id         String                @id @default(cuid())
  status     String                @default("open")
  costCents  Int                   @default(0)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  photos     CapturePhoto[]
  candidates RecognizedCandidate[]

  @@map("capture_sessions")
}

model CapturePhoto {
  id               String                @id @default(cuid())
  sessionId        String
  session          CaptureSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  storageKey       String                @unique
  url              String
  bytes            Int?
  status           String                @default("uploaded")
  recognitionError String?
  createdAt        DateTime              @default(now())
  candidates       RecognizedCandidate[]

  @@index([sessionId])
  @@map("capture_photos")
}

model RecognizedCandidate {
  id           String         @id @default(cuid())
  sessionId    String
  session      CaptureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  photoId      String
  photo        CapturePhoto   @relation(fields: [photoId], references: [id], onDelete: Cascade)
  name         String?
  producer     String?
  vintage      Int?
  region       String?
  country      String?
  type         String?
  confidence   Float?
  rawJson      Json
  status       String         @default("pending")
  linkedWineId String?
  bbox         Json?
  createdAt    DateTime       @default(now())

  @@index([sessionId])
  @@index([photoId])
  @@map("recognized_candidates")
}
