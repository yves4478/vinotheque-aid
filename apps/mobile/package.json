    "prebuild:prod": "APP_VARIANT=prod EXPO_PUBLIC_APP_ENV=prod EXPO_PUBLIC_API_URL=${EXPO_PUBLIC_PROD_API_URL:-http://acgw8kcgcg4wwwg00k8444ws.46.225.141.192.sslip.io} npx expo prebuild --clean --platform ios",
