# iOS Simulator / Android Emulator: localhost reaches the host Mac directly
EXPO_PUBLIC_API_URL=http://localhost:3000

# Real iPhone (development build): use your Mac's local IP address
# Find it with: ipconfig getifaddr en0   (macOS)
# Example:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:3000

# EAS Preview / Production build:
# EXPO_PUBLIC_API_URL=https://api.vinotheque.ch
