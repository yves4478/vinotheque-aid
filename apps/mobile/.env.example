# ── iPhone mit Expo Go (empfohlen) ────────────────────────────────────────────
# Prod-API direkt ansprechen – kein lokaler Tunnel nötig.
# Expo-Bundler via: npx expo start --tunnel
EXPO_PUBLIC_API_URL=https://api.vinotheque.ch
EXPO_PUBLIC_APP_ENV=prod

# ── Lokaler Simulator / Entwicklung ───────────────────────────────────────────
# EXPO_PUBLIC_API_URL=http://localhost:3000
# EXPO_PUBLIC_APP_ENV=dev

# ── Echtes iPhone gegen lokales Backend (UTM-VM) ──────────────────────────────
# VM-IP herausfinden: ip addr | grep "inet "
# Dann ngrok für Port 3000 starten: ngrok http 3000
# EXPO_PUBLIC_API_URL=https://<ngrok-subdomain>.ngrok-free.app
# EXPO_PUBLIC_APP_ENV=dev
